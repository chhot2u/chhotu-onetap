<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TRIGGER MODE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/trigger_mode"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rg_trigger_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rb_tap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tap"
                android:textSize="16sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_long_press"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/long_press"
                android:textSize="16sp" />

        </RadioGroup>

        <!-- DRAG DIRECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drag_direction"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rg_drag_direction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rb_up"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drag_up"
                android:textSize="14sp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rb_down"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drag_down"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/rb_left"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drag_left"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/rb_right"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/drag_right"
                android:textSize="14sp" />

        </RadioGroup>

        <!-- DRAG SPEED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drag_speed"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="300 ms"
            android:textSize="16sp"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_drag_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="50"
            android:max="2000"
            android:progress="300"
            android:layout_marginBottom="24dp" />

        <!-- DRAG DISTANCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drag_distance"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <Spinner
            android:id="@+id/spinner_distance"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

        <!-- START POSITION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_position"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_start_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="X: 50%"
                android:textSize="14sp"
                android:textColor="@color/gray_dark" />

            <TextView
                android:id="@+id/tv_start_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Y: 70%"
                android:textSize="14sp"
                android:textColor="@color/gray_dark" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/sb_start_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/sb_start_y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="70"
            android:layout_marginBottom="24dp" />

        <!-- END POSITION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/end_position"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_end_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="X: 50%"
                android:textSize="14sp"
                android:textColor="@color/gray_dark" />

            <TextView
                android:id="@+id/tv_end_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Y: 30%"
                android:textSize="14sp"
                android:textColor="@color/gray_dark" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/sb_end_x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/sb_end_y"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="30"
            android:layout_marginBottom="32dp" />

        <!-- BUTTONS -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/save_settings"
            android:textSize="18sp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/reset_defaults"
            android:textSize="16sp"
            android:backgroundTint="@color/gray_dark"
            android:textColor="@color/white" />

    </LinearLayout>

</ScrollView>
