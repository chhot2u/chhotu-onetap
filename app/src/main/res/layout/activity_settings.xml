<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ Panel Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginBottom="24dp" />

        <!-- PANEL SIZE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel Size"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_panel_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Normal"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_panel_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="2"
            android:progress="1"
            android:layout_marginBottom="20dp" />

        <!-- OPACITY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opacity"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_opacity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80%"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_opacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="20dp" />

        <!-- QUICK SWIPE DIRECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Swipe Direction"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_swipe_dir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <RadioButton android:id="@+id/rb_up" android:layout_width="0dp" android:layout_weight="1" android:text="↑ Up" android:checked="true" android:textColor="@color/white" />
            <RadioButton android:id="@+id/rb_down" android:layout_width="0dp" android:layout_weight="1" android:text="↓ Down" android:textColor="@color/white" />
            <RadioButton android:id="@+id/rb_left" android:layout_width="0dp" android:layout_weight="1" android:text="← Left" android:textColor="@color/white" />
            <RadioButton android:id="@+id/rb_right" android:layout_width="0dp" android:layout_weight="1" android:text="→ Right" android:textColor="@color/white" />

        </RadioGroup>

        <!-- SWIPE SPEED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe Speed"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_swipe_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="300 ms"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_swipe_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="300"
            android:layout_marginBottom="20dp" />

        <!-- SWIPE DISTANCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe Distance"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_distance"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp" />

        <!-- AUTO FIRE SPEED -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auto Fire Speed"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_auto_fire"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100 ms"
            android:textSize="16sp"
            android:textColor="@color/accent2"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_auto_fire"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="500"
            android:progress="100"
            android:layout_marginBottom="20dp" />

        <!-- RAPID TAP INTERVAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rapid Tap Interval"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_rapid_tap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50 ms"
            android:textSize="16sp"
            android:textColor="@color/accent3"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_rapid_tap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="50"
            android:layout_marginBottom="20dp" />

        <!-- COMBO DELAY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Combo Delay"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_combo_delay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200 ms"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/sb_combo_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="200"
            android:layout_marginBottom="24dp" />

        <!-- BUTTONS -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 Save Settings"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔄 Reset Defaults"
            android:textSize="14sp"
            android:backgroundTint="@color/bg_button"
            android:textColor="@color/accent2" />

    </LinearLayout>

</ScrollView>
